    },
    "host": "localhost:9090",
    "basePath": "/api/v1/",
    "paths": {
        "/getproducts": {
            "get": {
                "description": "Get available product family types",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Get a list of available product family types",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.ProductFamily"
                            }
                        }
                    }
                }
            }
        },
        "/markovstates": {
            "get": {
                "description": "Get available Transition (Markov) states",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Get a list of available transition states",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.MarkovState"
                            }
                        }
                    }
                }
            }
        },
        "/modelpointvariables": {
            "get": {
                "description": "get all model point variables",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Get a list of available model point variables",
                "operationId": "getAllModelPointvariables",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.ModelPointVariable"
                            }
                        }
                    }
                }
            }
        },
        "/modelpointvariables/{prodId}": {
            "get": {
                "description": "get all applicable model point variables for a product",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Get a list of model point variables for product",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Product Code",
                        "name": "prodId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.ModelPointVariable"
                            }
                        }
                    }
                }
            }
        },
        "/products/assumptions/variables": {
            "get": {
                "description": "This will return all assumption variables available for product configuration",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "products"
                ],
                "summary": "Get all available assumption variables",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.BaseAssumptionVariable"
                            }
                        }
                    }
                }
            }
        },
        "/products/features": {
            "get": {
                "description": "This will return all benefit features available for product configuration",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "products"
                ],
                "summary": "Get all available benefit features",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.BaseFeature"
                            }
                        }
                    }
                }
            }
        },
        "/upload": {
            "post": {
                "description": "Use this endpoint to upload a completed product configuration",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Upload a valid product configuration",
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/models.Product"
                        }
                    }
                }
            }
        }
    },
